{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2015",
    "declaration": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "noImplicitAny": true,
    "lib": ["dom", "esnext", "es6", "es7"],
    "allowUmdGlobalAccess": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "doc",
    "test",
    "dist",
    "vite.config.ts"
  ]
}
